        //- テーブルパーツ
        table.table 
          tr
            td.table_head TITLE
            td.table_text 東京都中央区-M37
          tr
            td.table_head 所在地
            td.table_text 東京都中央区
          tr
            td.table_head 築年・面積
            td.table_text 築15年・マンション専用部分37.1平米
          tr
