.l-contents 
  .l-contents__wrapper 
    .article
      main.articleMain
        //- メイン画像　
        .articleMain__img: img(src=`${DUMMY_DIR}top/modal-full.jpg`)
        //- タイトル
        p.articleMain__title.f-intel-B Minamiaoyama office-M  
        //- ジャンル・日付　
        p.articleMain__info.f-intel-B (     #{parts.genre}, #{parts.date}     )
        

      section.articleContents
        //- 見出し
        p.articleContents__head.f-noto-B!=parts.head

        //- テキスト
        p.articleContents__text.f-noto-M!=parts.text1

        //- テキスト
        p.articleContents__text.f-noto-M!=parts.text2

        //- w100写真パーツ
        .articleContents__img-full
          .img: img(src=`${DUMMY_DIR}page/full.jpg`)
          p.cap.f-noto-M!=parts.cap
                
        //- 見出し
        p.articleContents__head.f-noto-B ディテール

        //- テキスト
        p.articleContents__text.f-noto-M!=parts.text1

        //- テキスト
        p.articleContents__text.f-noto-M!=parts.text2 

        //- 横並び２カラムパーツ(テキスト)
